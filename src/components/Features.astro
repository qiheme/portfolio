---
import { features } from "../data/content";
---

<div class="relative bg-primary-900 -mx-8 px-8 text-gray-100">
  <div
    class="flex flex-col items-center md:items-stretch md:flex-row flex-wrap md:justify-center max-w-[1024px] mx-auto py-20 md:py-24"
  >
    {
      features.subheading && (
        <h5 class="font-bold text-primary-500 mb-4 text-gray-100">
          {features.subheading}
        </h5>
      )
    }
    <h2
      class="text-4xl sm:text-5xl font-black tracking-wide text-center w-full"
    >
      {features.heading}
    </h2>
    {
      features.description && (
        <p class="mt-4 text-sm md:text-base lg:text-lg font-medium leading-relaxed max-w-xl w-full text-center text-gray-300">
          {features.description}
        </p>
      )
    }
    <div class="mt-10 w-full"></div>
    {
      features.cards.map((card) => (
        <div class="md:w-1/2 lg:w-1/3 max-w-xs">
          <div class="flex flex-col items-center sm:items-start text-center sm:text-left h-full mx-4 px-2 py-8">
            <span class="bg-gray-100 text-center rounded-full p-5 flex-shrink-0">
              <img src={card.icon} alt="" class="w-6 h-6" />
            </span>
            <span class="mt-6">
              <span class="tracking-wider font-bold text-xl leading-none">
                {card.title}
              </span>
              <p class="mt-2 font-normal text-gray-400 leading-snug">
                {card.description}
              </p>
            </span>
          </div>
        </div>
      ))
    }
  </div>
</div>

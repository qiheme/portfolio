---
interface Props {
  heading: string;
  description: string;
  imageSrc: string;
  textOnLeft?: boolean;
}

const { heading, description, imageSrc, textOnLeft = true } = Astro.props;
---

<div class="relative">
  <div class="flex flex-col md:flex-row justify-between max-w-screen-xl mx-auto py-20 md:py-24 items-center">
    <!-- Image Column -->
    <div class="w-full max-w-md mx-auto md:max-w-none md:mx-0 md:w-6/12 flex-shrink-0 relative">
      <img
        src={imageSrc}
        alt=""
        class="rounded"
      />
    </div>

    <!-- Text Column -->
    <div
      class:list={[
        "w-full max-w-md mx-auto md:max-w-none md:mx-0 md:w-6/12 mt-16 md:mt-0",
        textOnLeft ? "md:mr-12 lg:mr-16 md:order-first" : "md:ml-12 lg:ml-16 md:order-last"
      ]}
    >
      <div class="lg:py-8 text-center md:text-left">
        <h2 class="mt-4 font-black text-left text-3xl sm:text-4xl lg:text-5xl text-center md:text-left leading-tight">
          {heading}
        </h2>
        <p class="mt-4 text-center md:text-left text-sm md:text-base lg:text-lg font-medium leading-relaxed text-secondary-100">
          {description}
        </p>
      </div>
    </div>
  </div>
</div>

---
const currentYear = new Date().getFullYear();
---

<footer class="relative bg-gray-900 text-gray-100 -mx-8 -mb-8">
  <div class="max-w-screen-xl mx-auto py-20 lg:py-24">
    <div class="flex items-center justify-center flex-col px-8">
      <!-- Logo -->
      <div class="flex items-center justify-center md:justify-start">
        <h5 class="ml-2 text-2xl font-black tracking-wider">Quincy Iheme</h5>
      </div>

      <!-- Links -->
      <div class="mt-8 font-medium flex flex-wrap justify-center items-center flex-col sm:flex-row">
        <a
          href="#"
          class="border-b-2 border-transparent hover:text-gray-300 hover:border-gray-300 pb-1 transition duration-300 mt-2 mx-4"
        >
          Home
        </a>
      </div>

      <!-- Social Links -->
      <div class="mt-10 flex">
        <a
          href="https://twitter.com/codespeakteach"
          target="_blank"
          rel="noopener noreferrer"
          class="cursor-pointer inline-block text-gray-100 hover:text-gray-500 transition duration-300 mx-4"
          aria-label="Twitter"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.954 4.569c-.885.389-1.83.654-2.825.775 1.014-.611 1.794-1.574 2.163-2.723-.951.555-2.005.959-3.127 1.184-.896-.959-2.173-1.559-3.591-1.559-2.717 0-4.92 2.203-4.92 4.917 0 .39.045.765.127 1.124C7.691 8.094 4.066 6.13 1.64 3.161c-.427.722-.666 1.561-.666 2.475 0 1.71.87 3.213 2.188 4.096-.807-.026-1.566-.248-2.228-.616v.061c0 2.385 1.693 4.374 3.946 4.827-.413.111-.849.171-1.296.171-.314 0-.615-.03-.916-.086.631 1.953 2.445 3.377 4.604 3.417-1.68 1.319-3.809 2.105-6.102 2.105-.39 0-.779-.023-1.17-.067 2.189 1.394 4.768 2.209 7.557 2.209 9.054 0 14-7.496 14-13.986 0-.209 0-.42-.015-.63.961-.689 1.8-1.56 2.46-2.548l-.047-.02z"/>
          </svg>
        </a>
        <a
          href="https://instagram.com/codespeakteach"
          target="_blank"
          rel="noopener noreferrer"
          class="cursor-pointer inline-block text-gray-100 hover:text-gray-500 transition duration-300 mx-4"
          aria-label="Instagram"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-center mt-10 font-medium tracking-wide text-sm text-gray-600">
        &copy; Copyright {currentYear}. All Rights Reserved.
      </p>
    </div>
  </div>
</footer>
